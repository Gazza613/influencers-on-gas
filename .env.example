# GAS Studio environment variables. Copy to .env.local for dev; set the same
# in Vercel (Production) for deploys. Never commit real values.

# ── Auth (Auth.js v5) ─────────────────────────────────────────────────────────
AUTH_SECRET=            # `openssl rand -base64 32`
SUPER_ADMIN_EMAIL=gary@gasmarketing.co.za
SUPER_ADMIN_PASSWORD=   # v1 super-admin password (moves to users table in Phase 1b)

# ── Database (Neon Postgres + pgvector) ───────────────────────────────────────
DATABASE_URL=           # Neon pooled connection string (provision via Vercel Marketplace)

# ── Producer / LLM (Anthropic) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=      # Sonnet 4.6 default / Opus 4.8 premium / Haiku 4.5 ingestion

# ── Embeddings + crawl (RAG) ──────────────────────────────────────────────────
VOYAGE_API_KEY=         # voyage-3.5 (1024-dim)
FIRECRAWL_API_KEY=      # website ingestion

# ── Audio (ElevenLabs: TTS, Music v2, SFX, Scribe STT) ────────────────────────
ELEVENLABS_API_KEY=

# ── Avatar / a-roll (HeyGen) ──────────────────────────────────────────────────
HEYGEN_API_KEY=

# ── Identity + b-roll (Higgsfield) ────────────────────────────────────────────
HIGGSFIELD_API_KEY=

# ── Realism (Magnific / Freepik) ──────────────────────────────────────────────
MAGNIFIC_API_KEY=

# ── Assembly (Shotstack) ──────────────────────────────────────────────────────
SHOTSTACK_API_KEY=

# ── Storage (Vercel Blob) ─────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Knowledge ingestion (Google Sheets + Drive, GAS service account) ──────────
GOOGLE_SERVICE_ACCOUNT_JSON=   # base64 or path; read access to client Drive folders

# ── Email digests (Gmail) + cron auth ─────────────────────────────────────────
GMAIL_USER=             # grow@gasmarketing.co.za (sends the cost + Higgsfield-ideas emails)
GMAIL_APP_PASSWORD=     # Gmail app password for the above
COST_EMAIL_TO=gary@gasmarketing.co.za   # daily cost digest recipient
ALERT_EMAIL_TO=                         # platform-alert recipient (out-of-credits, API down, build failed). Defaults to SUPER_ADMIN_EMAIL / COST_EMAIL_TO / gary@
TIPS_EMAIL_TO=          # Higgsfield-ideas recipient (defaults to COST_EMAIL_TO / gary@)
INTEL_EMAIL_TO=         # Strategist/Journalist daily digest. Comma-separated; overrides the default (COST_EMAIL_TO + sam@)
CRON_SECRET=            # REQUIRED for scheduled crons: Vercel sends `Authorization: Bearer $CRON_SECRET`. Without it, scheduled crons 401 and never send.
